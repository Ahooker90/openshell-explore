# === OpenShell example-agent configuration ===
# This is the ONLY file you change to move between local and corporate backends.
# After editing, re-run ./setup.sh — the agent and sandbox commands never change.

# Name of the OpenShell provider record this example creates/replaces.
PROVIDER_NAME=ollama-local

# ---------------------------------------------------------------------------
# LOCAL — Ollama running on your host (defaults; verified with this example)
# ---------------------------------------------------------------------------
MODEL=nemotron:latest
# How the GATEWAY/SANDBOX reaches your host's Ollama. `host.openshell.internal`
# is the host alias OpenShell injects into the sandbox; 11434 is Ollama's port.
BACKEND_BASE_URL=http://host.openshell.internal:11434/v1
# Ollama needs no auth; the OpenAI provider type still wants a value, so use a
# placeholder. (SDKs reject an empty key, hence the literal "empty".)
BACKEND_API_KEY=empty

# ---------------------------------------------------------------------------
# CORPORATE — any OpenAI-compatible endpoint (vLLM, NIM, TGI, LiteLLM, ...)
# To switch: comment out the three LOCAL lines above and uncomment these,
# then re-run ./setup.sh. Nothing else changes.
# ---------------------------------------------------------------------------
# MODEL=meta-llama/Llama-3.1-70B-Instruct
# BACKEND_BASE_URL=https://vllm.corp.example.com/v1
# BACKEND_API_KEY="$CORP_LLM_TOKEN"     # export CORP_LLM_TOKEN=... in your shell first
